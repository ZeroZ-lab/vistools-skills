#!/bin/bash
# Platform-aware wrapper for vistools binary.
# Detects OS and architecture, then runs the correct pre-compiled binary
# located alongside this script (e.g., bin/vistools-macos-arm64).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

case "$OS" in
  darwin) OS_TAG="macos" ;;
  linux)  OS_TAG="linux" ;;
  *)
    echo "Error: unsupported OS '$OS'" >&2
    exit 1
    ;;
esac

case "$ARCH" in
  x86_64|amd64)  ARCH_TAG="x64" ;;
  aarch64|arm64) ARCH_TAG="arm64" ;;
  *)
    echo "Error: unsupported architecture '$ARCH'" >&2
    exit 1
    ;;
esac

BIN="${SCRIPT_DIR}/vistools-${OS_TAG}-${ARCH_TAG}"

if [ ! -x "$BIN" ]; then
  echo "Error: vistools binary not found for ${OS_TAG}-${ARCH_TAG}" >&2
  echo "Expected: ${BIN}" >&2
  echo "" >&2
  echo "To install from source:" >&2
  echo "  git clone https://github.com/ZeroZ-lab/vistools" >&2
  echo "  cd vistools && cargo build --release" >&2
  echo "  cp target/release/vistools ${BIN}" >&2
  exit 1
fi

exec "$BIN" "$@"
